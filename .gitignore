# Python cache
__pycache__/
*.py[cod]

# SQLite runtime DB — keep tracked locally so data survives restarts
# (add users.db back to gitignore only if deploying to production)

# Uploaded storage — track the folder, ignore the file contents
storage/*
!storage/.gitkeep

# Virtualenvs
.venv/
env/

# IDEs
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
